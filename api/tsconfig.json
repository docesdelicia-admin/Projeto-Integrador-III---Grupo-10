{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    "rootDir": "..",
    "outDir": "dist",
    "baseUrl": "./",
    "paths": {
      "@vercel/node": ["./node_modules/@vercel/node"],
      "@neondatabase/serverless": ["./node_modules/@neondatabase/serverless"],
      "bcryptjs": ["./node_modules/bcryptjs"],
      "jsonwebtoken": [
        "./node_modules/@types/jsonwebtoken/index.d.ts",
        "./node_modules/jsonwebtoken"
      ]
    }
  },
  "include": ["./**/*.ts", "../services/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
