{
  "version": 2,
  "outputDirectory": "public",
  "builds": [
    {
      "src": "auth/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "clientes/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "insumos/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "estoque_insumos/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "pedidos/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "produtos/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "usuarios/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/$1"
    }
  ]
}